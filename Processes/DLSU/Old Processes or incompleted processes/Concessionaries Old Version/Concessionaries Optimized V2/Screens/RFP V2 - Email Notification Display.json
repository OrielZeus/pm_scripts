{
  "type": "screen_package",
  "version": "2",
  "screens": [
    {
      "title": "RFP V2 - Email Notification Display",
      "description": "Optional display screen for notification payload preview",
      "type": "DISPLAY",
      "config": [
        {
          "name": "Email Notification",
          "items": [
            {
              "items": [
                [
                  {
                    "label": "Rich Text",
                    "component": "FormHtmlViewer",
                    "config": {
                      "content": "<h3>Email Notification Preview</h3><p><strong>To:</strong> {{approver_email}}</p><p><strong>Subject:</strong> {{subject_header}}</p><p><strong>Message:</strong> {{email_error_message}}</p><p><strong>RFP Number:</strong> {{number}}</p>"
                    }
                  }
                ]
              ]
            }
          ]
        }
      ],
      "computed": []
    }
  ],
  "screen_categories": [],
  "scripts": []
}
